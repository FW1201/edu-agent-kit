# edu-agent-kit — environment variables (all optional)
# Copy to .env and fill in the keys for the platforms you use.
# Where to get each key: docs/API-SETUP.md

# Padlet official API — https://padlet.com/dashboard/settings/developers
PADLET_API_KEY=

# Google OAuth2 (Docs/Slides/Forms/Sheets/Drive/Classroom)
# Google Cloud Console > APIs & Services > Credentials > OAuth client (Desktop)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional overrides:
# GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
# GOOGLE_TOKEN_PATH=./.tokens/google-token.json

# Kahoot Reports API (EDU/enterprise plan)
KAHOOT_API_KEY=

# Note: web search is NOT a separate integration here — use your agent's
# built-in web search capability and feed findings to content_ingest_source
# (file/URL) or directly into the conversation.

# Firebase Hosting — firebase login:ci  (token); project id from Firebase Console
FIREBASE_TOKEN=
FIREBASE_PROJECT=

# Transport (optional): set to "http" for Streamable HTTP instead of stdio
# TRANSPORT=stdio
# PORT=3000
