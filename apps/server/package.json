{
  "name": "interactive-edtech-mcp-server",
  "version": "0.1.0",
  "description": "Single MCP server exposing content-generation, classroom-platform, and end-to-end workflow tools for interactive-edtech-mcp.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "interactive-edtech-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@interactive-edtech/core": "workspace:*",
    "@interactive-edtech/mcp-shared": "workspace:*",
    "@interactive-edtech/sources": "workspace:*",
    "@interactive-edtech/padlet": "workspace:*",
    "@interactive-edtech/google-classroom": "workspace:*",
    "@interactive-edtech/kahoot": "workspace:*",
    "@interactive-edtech/wayground": "workspace:*",
    "@interactive-edtech/wordwall": "workspace:*",
    "@interactive-edtech/nearpod": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  }
}
