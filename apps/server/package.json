{
  "name": "edu-agent-kit-server",
  "version": "0.1.0",
  "description": "Single MCP server exposing content-generation, classroom-platform, and end-to-end workflow tools for edu-agent-kit.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "edu-agent-kit-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@edu-agent-kit/core": "workspace:*",
    "@edu-agent-kit/mcp-shared": "workspace:*",
    "@edu-agent-kit/sources": "workspace:*",
    "@edu-agent-kit/padlet": "workspace:*",
    "@edu-agent-kit/google-classroom": "workspace:*",
    "@edu-agent-kit/google-workspace": "workspace:*",
    "@edu-agent-kit/docx": "workspace:*",
    "@edu-agent-kit/teach-apps": "workspace:*",
    "@edu-agent-kit/firebase": "workspace:*",
    "@edu-agent-kit/wiki-kit": "workspace:*",
    "@edu-agent-kit/kahoot": "workspace:*",
    "@edu-agent-kit/wayground": "workspace:*",
    "@edu-agent-kit/wordwall": "workspace:*",
    "@edu-agent-kit/nearpod": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21"
  }
}
